# ============================================
# ITAM System - Variables de Entorno
# ============================================
# Copia este archivo como .env y configura los valores

# --- BASE DE DATOS PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=tu_password_seguro
DB_HOST=localhost
DB_PORT=5432
DB_NAME=itam_db

# --- SEGURIDAD JWT ---
# IMPORTANTE: En producción, usa una clave generada aleatoriamente
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar_esto_por_una_clave_segura_de_64_caracteres_minimo

# --- TOKEN PARA AGENTES ---
# Los agentes de escritorio usan este token para reportar
API_TOKEN=sk_live_cambiar_por_token_seguro

# --- SNMP COMMUNITY STRING ---
# Cambia el community string por defecto de las impresoras
# IMPORTANTE: Debe coincidir con la configuración de cada impresora
SNMP_COMMUNITY=Tu_Community_Seguro_2026

# --- CORS (Orígenes permitidos) ---
# Separa múltiples orígenes con comas
ALLOWED_ORIGINS=http://localhost:5173,http://tu-servidor.dominio.pe

# --- RATE LIMITING ---
# Límite de peticiones por minuto para el endpoint de login
LOGIN_RATE_LIMIT=5

# Límite general de peticiones por minuto
API_RATE_LIMIT=100

# --- LOGGING ---
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
